# ═══════════════════════════════════════════════════════════
# AI PROVIDER — the single switch that controls everything
#
#   AI_PROVIDER=openai   → production  (OpenAI GPT + embeddings)
#   AI_PROVIDER=groq     → development (Groq llama + local embeddings)
# ═══════════════════════════════════════════════════════════
AI_PROVIDER=openai

# ── App ──────────────────────────────────────────────────

APP_NAME="Enterprise AI Agent Platform"
APP_VERSION=2.0.0
DEBUG=False
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
RELOAD=False

# ── Database ─────────────────────────────────────────────

DATABASE_URL=postgresql://mahbubdb:mahbub123@localhost:5432/ai_agent_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis ────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json

# ── JWT ──────────────────────────────────────────────────

SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════════════
# PRODUCTION — AI_PROVIDER=openai
# Install: pip install -r requirements/prod.txt
# ═══════════════════════════════════════════════════════════

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ═══════════════════════════════════════════════════════════
# DEVELOPMENT — AI_PROVIDER=groq
# Install: pip install -r requirements/dev.txt
# (leave OPENAI_API_KEY empty — not needed)
# ═══════════════════════════════════════════════════════════

GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_SMART_MODEL=llama-3.3-70b-versatile
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── Governance ───────────────────────────────────────────

ENABLE_GOVERNANCE=True
ENABLE_HALLUCINATION_CHECK=True
HALLUCINATION_THRESHOLD=60.0
ENABLE_RISK_ASSESSMENT=True
RISK_ESCALATION_THRESHOLD=70
ENABLE_COST_CONTROL=True
MAX_COST_PER_REQUEST=10.0
MONTHLY_BUDGET_LIMIT=500.0
ENABLE_USAGE_TRACKING=True

# ── Embeddings ───────────────────────────────────────────

EMBEDDING_DIMENSION=384
SIMILARITY_THRESHOLD=0.7

# ── Token Budgets ────────────────────────────────────────

MAX_CONTEXT_TOKENS=8000
MAX_OUTPUT_TOKENS=2000
SUMMARY_THRESHOLD_MESSAGES=20

# ── Rate Limiting ────────────────────────────────────────

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── CORS ─────────────────────────────────────────────────

CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── AWS S3 ───────────────────────────────────────────────

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=enterprise-ai-chatbot

# ── Stripe ───────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
BILLING_SUCCESS_URL=https://app.example.com/billing/success
BILLING_CANCEL_URL=https://app.example.com/billing/cancel
BILLING_PORTAL_RETURN_URL=https://app.example.com/billing

# ── Integrations ─────────────────────────────────────────

WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
INSTAGRAM_VERIFY_TOKEN=your-instagram-verify-token
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
MESSENGER_ACCESS_TOKEN=your-messenger-access-token
MESSENGER_VERIFY_TOKEN=your-messenger-verify-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
WEBHOOK_SECRET=your-generic-webhook-secret

# ── Monitoring ───────────────────────────────────────────

ENABLE_MONITORING=True
SENTRY_DSN=



