{
  "family": "ai-agent-beat",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "beat",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/ai-agent-platform:latest",
      "command": [
        "celery", "-A", "app.workers.celery_config", "beat", "--loglevel=info"
      ],
      "environment": [
        { "name": "AI_PROVIDER", "value": "openai" },
        { "name": "LOG_LEVEL",   "value": "INFO" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:ai-agent/DATABASE_URL" },
        { "name": "REDIS_URL",    "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:ai-agent/REDIS_URL" },
        { "name": "SECRET_KEY",   "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:ai-agent/SECRET_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-agent-beat",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "beat"
        }
      },
      "essential": true
    }
  ]
}
